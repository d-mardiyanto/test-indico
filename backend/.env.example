# Backend configuration. Copy to `.env` and adjust as needed.
# All values are optional; defaults are shown.

# HTTP listen port for the Gin server.
PORT=8080

# NETPLAY partner API base URL (no trailing slash).
NETPLAY_BASE_URL=https://ctazh5lrhe.execute-api.ap-southeast-3.amazonaws.com/dev/api

# Base URL of the frontend. Used for:
#   1. Building the activation link returned in the SMS-style payload.
#   2. CORS AllowOrigins.
FRONTEND_BASE_URL=http://localhost:5173

# Per-request timeout (in ms) for outbound calls to partner APIs.
HTTP_TIMEOUT_MS=5000
